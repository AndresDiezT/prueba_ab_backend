APP_NAME="AB Comercial API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# base de datos local PostgreSQL.
# Formato: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dbp_ab_comercial

# Utilice un valor aleatorio largo en implementaciones reales.
SECRET_KEY=change-this-secret-key-with-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Lista separada por comas.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
