APP_NAME="AB Comercial API"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Local PostgreSQL database.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dbp_ab_comercial

# Use a long random value in real deployments.
SECRET_KEY=change-this-secret-key-with-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Comma-separated list.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Request/application logs. The file rotates automatically by size.
LOG_FILE_PATH=logs/app.log
LOG_MAX_BYTES=1000000
LOG_BACKUP_COUNT=5
