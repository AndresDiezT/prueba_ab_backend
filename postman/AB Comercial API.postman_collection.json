{
  "info": {
    "_postman_id": "7d9f73e8-4b06-4d3c-a6e7-ab-comercial-api",
    "name": "AB Comercial API",
    "description": "Colección para probar autenticación JWT, RBAC y CRUD de vehículos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "vehicle_id",
      "value": "1"
    },
    {
      "key": "admin_username",
      "value": "admin"
    },
    {
      "key": "admin_password",
      "value": "Admin12345"
    },
    {
      "key": "new_viewer_username",
      "value": "viewer_demo@example.com"
    },
    {
      "key": "new_viewer_password",
      "value": "Viewer12345!"
    }
  ],
  "item": [
    {
      "name": "Salud",
      "item": [
        {
          "name": "Verificar API",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Autenticación",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('Login exitoso', function () {",
                  "  pm.expect(response.success).to.eql(true);",
                  "  pm.expect(response.data.access_token).to.be.a('string');",
                  "});",
                  "pm.collectionVariables.set('access_token', response.data.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{admin_username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{admin_password}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Registrar Viewer Publico",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{new_viewer_username}}\",\n  \"password\": \"{{new_viewer_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Crear Usuario por Admin",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{new_viewer_username}}\",\n  \"password\": \"{{new_viewer_password}}\",\n  \"role\": \"viewer\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/users",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "users"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Vehículos",
      "item": [
        {
          "name": "Listar Vehículos",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vehicles?skip=0&limit=100",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles"
              ],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            }
          }
        },
        {
          "name": "Obtener Vehículo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vehicles/{{vehicle_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles",
                "{{vehicle_id}}"
              ]
            }
          }
        },
        {
          "name": "Crear Vehículo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test('Vehículo creado', function () {",
                  "  pm.expect(response.success).to.eql(true);",
                  "  pm.expect(response.data.id).to.be.a('number');",
                  "});",
                  "pm.collectionVariables.set('vehicle_id', response.data.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Chevrolet\",\n  \"arrival_location\": \"Barranquilla\",\n  \"applicant_name\": \"Juan Perez\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/vehicles",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles"
              ]
            }
          }
        },
        {
          "name": "Actualizar Vehículo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brand\": \"Chevrolet\",\n  \"arrival_location\": \"Cartagena\",\n  \"applicant_name\": \"Juan Perez\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/vehicles/{{vehicle_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles",
                "{{vehicle_id}}"
              ]
            }
          }
        },
        {
          "name": "Eliminar Vehículo",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/vehicles/{{vehicle_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "vehicles",
                "{{vehicle_id}}"
              ]
            }
          }
        }
      ]
    }
  ]
}
